#!/usr/bin/env bash
# Copy to scripts/llm_endpoint.env and edit as needed:
#   cp scripts/llm_endpoint.env.example scripts/llm_endpoint.env
#   ./scripts/run_llm_endpoint.sh

PYTHON_BIN="python3"
LLM_ENDPOINT_HOST="127.0.0.1"
LLM_ENDPOINT_PORT="8081"

# Local Ollama service for semantic label verification.
export OLLAMA_URL="http://127.0.0.1:11434"
export PERTURB_LLM_ENDPOINT_MODEL="qwen2.5:1.5b-instruct"
export OLLAMA_TIMEOUT_SECONDS="30"
