#!/usr/bin/env bash
# Copy to scripts/miner.env and edit values before running:
#   cp scripts/miner.env.example scripts/miner.env
#   bash ./scripts/run_miner.sh

# Required
WALLET_NAME="miner"
WALLET_HOTKEY="default"

# Network
NETUID="1"
NETWORK="finney"
SUBTENSOR_CHAIN_ENDPOINT=""

# Optional
PYTHON_BIN="python3"
LOG_LEVEL="DEBUG"
MINER_IP="0.0.0.0"
MINER_EXTERNAL_IP="157.157.221.29"
MINER_PORT="9000"
MINER_EXTERNAL_PORT="49814"
MINER_EXTRA_ARGS=""

export PERTURB_STRICT_ONE_STEP_LINF=1
export PERTURB_ATTACK_PRESET=default
export ATTACK_LOG_EXCEL=0
export PERTURB_SPARSE_FALLBACK_MAX_CANDIDATES=20000